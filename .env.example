ORCHARD_BACKEND=mock
ORCHARD_MODEL=mock/orchard-test
ORCHARD_MODEL_ARCHITECTURE=mock
ORCHARD_MODEL_QUANTIZATION=none
ORCHARD_MPS_DTYPE=float16
ORCHARD_HOST=127.0.0.1
ORCHARD_PORT=8000
ORCHARD_LOG_LEVEL=INFO
ORCHARD_MOCK_TOKEN_DELAY_SECONDS=0
ORCHARD_MOCK_FAIL_LOAD=false
ORCHARD_MOCK_FAIL_GENERATION=false
# ORCHARD_MOCK_FAIL_AFTER_TOKENS=2
ORCHARD_MOCK_MEMORY_PRESSURE=false
# ORCHARD_MOCK_UNHEALTHY_AFTER_REQUESTS=1
ORCHARD_REQUEST_TIMEOUT_SECONDS=30
ORCHARD_STREAM_BUFFER_SIZE=8
ORCHARD_SHUTDOWN_GRACE_SECONDS=10
ORCHARD_SCHEDULING_POLICY=fifo
ORCHARD_MAX_QUEUED_REQUESTS=64
ORCHARD_MAX_ACTIVE_REQUESTS=4
ORCHARD_MAX_PROMPT_TOKENS=4096
ORCHARD_MAX_OUTPUT_TOKENS=1024
ORCHARD_MAX_TOTAL_ESTIMATED_TOKENS=8192
ORCHARD_SCHEDULER_AGING_SECONDS=5
ORCHARD_MAX_BATCH_SIZE=4
ORCHARD_MAX_BATCH_WAIT_SECONDS=0.005
ORCHARD_BATCH_TOKEN_BUDGET=8192
ORCHARD_PROMPT_CACHE_ENABLED=true
ORCHARD_TOKENIZATION_CACHE_ENABLED=true
ORCHARD_CACHE_MAX_ENTRIES=1024
ORCHARD_CACHE_MAX_BYTES=67108864
ORCHARD_CACHE_TTL_SECONDS=300
ORCHARD_PREFIX_ROUTER_ENABLED=true
ORCHARD_PREFIX_ROUTER_MIN_MATCH_TOKENS=8
ORCHARD_PREFIX_ROUTER_MAX_PREFIX_TOKENS=2048
# Set this only when using the MLX backend:
# ORCHARD_BACKEND=mlx
# ORCHARD_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
# ORCHARD_MODEL_ARCHITECTURE=qwen2.5-3b-instruct
# ORCHARD_MODEL_QUANTIZATION=4bit
